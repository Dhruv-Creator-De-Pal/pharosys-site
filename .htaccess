# Pharosys .htaccess - Security and Performance Configuration
# Place this file in your web root directory

# Enable HTTPS Redirect
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Enable GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache Control - Static Files (CSS, JS, Images)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    # HTML files - shorter cache
    ExpiresByType text/html "access plus 1 week"
</IfModule>

# File Caching Headers
<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable" ".css"
    Header set Cache-Control "public, max-age=31536000, immutable" ".js"
    Header set Cache-Control "public, max-age=31536000, immutable" ".jpg"
    Header set Cache-Control "public, max-age=31536000, immutable" ".jpeg"
    Header set Cache-Control "public, max-age=31536000, immutable" ".gif"
    Header set Cache-Control "public, max-age=31536000, immutable" ".png"
    Header set Cache-Control "public, max-age=31536000, immutable" ".woff"
    Header set Cache-Control "public, max-age=31536000, immutable" ".woff2"
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Strict Transport Security (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    
    # Prevent MIME Type Sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Clickjacking Protection
    Header set X-Frame-Options "DENY"
    
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove X-Powered-By Header
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# Disable Directory Browsing
Options -Indexes

# Block Access to Sensitive Files
<FilesMatch "\.env|\.htaccess|\.git|\.gitignore|composer\.json|composer\.lock|\.htpasswd">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block Access to Common Malicious File Names
<FilesMatch "(wp-config|php\.ini|\.sql|web\.config)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Strong File Permissions (recommended to set via FTP/SSH)
# chmod 644 for files, 755 for directories

# Enable PHP Security
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value default_charset "UTF-8"
</IfModule>

# Prevent SQL Injection and XSS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{QUERY_STRING} (~|%7E) [OR]
    RewriteCond %{QUERY_STRING} \.\. [OR]
    RewriteCond %{QUERY_STRING} ^.*(\<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} ^.*(%27)|(\'|--|%23) [NC]
    RewriteRule .* - [F]
</IfModule>

# Deny Access via User-Agent
<IfModule mod_setenvif.c>
    SetEnvIfNoCase User-Agent "^.*bot.*" bad_bot
    SetEnvIfNoCase User-Agent "^.*crawler.*" bad_bot
    <RequireAll>
        Require all granted
        Require not env bad_bot
    </RequireAll>
</IfModule>

# Add Charset
AddCharset UTF-8 .html .css .js .xml .json .rss .atom